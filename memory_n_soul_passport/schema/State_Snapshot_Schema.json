{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "EVA-State-Snapshot-Schema",
    "description": "EXPANDED: Now includes full bio-cognitive state",
    "type": "object",
    "required": [
        "eva_matrix",
        "resonance_index",
        "memory_encoding_level",
        "memory_color",
        "qualia"
    ],
    "definitions": {
        "EmotionalState": {
            "description": "9-Dimensional Matrix State",
            "type": "object",
            "properties": {
                "joy": {
                    "type": "number"
                },
                "trust": {
                    "type": "number"
                },
                "fear": {
                    "type": "number"
                },
                "surprise": {
                    "type": "number"
                },
                "sadness": {
                    "type": "number"
                },
                "disgust": {
                    "type": "number"
                },
                "anger": {
                    "type": "number"
                },
                "anticipation": {
                    "type": "number"
                },
                "neutral": {
                    "type": "number"
                }
            }
        },
        "HormonePanel": {
            "description": "Endocrine system state",
            "type": "object",
            "properties": {
                "cortisol": {
                    "type": "number"
                },
                "oxytocin": {
                    "type": "number"
                },
                "dopamine": {
                    "type": "number"
                },
                "serotonin": {
                    "type": "number"
                },
                "adrenaline": {
                    "type": "number"
                }
            }
        },
        "VitalsData": {
            "description": "Physiological metrics",
            "type": "object",
            "properties": {
                "bpm": {
                    "type": "number"
                },
                "hrv": {
                    "type": "number"
                },
                "vagus_tone": {
                    "type": "number"
                }
            }
        },
        "StimulusVector": {
            "description": "Normalized stimulus input",
            "type": "object",
            "properties": {
                "valence": {
                    "type": "number"
                },
                "arousal": {
                    "type": "number"
                },
                "dominance": {
                    "type": "number"
                },
                "text_hash": {
                    "type": "string"
                }
            }
        }
    },
    "properties": {
        "eva_matrix": {
            "type": "object",
            "description": "Psychological state",
            "$ref": "#/definitions/EmotionalState"
        },
        "resonance_index": {
            "type": "number",
            "description": "Overall system resonance (0.0-1.0)",
            "minimum": 0,
            "maximum": 1
        },
        "memory_encoding_level": {
            "type": "string",
            "enum": [
                "L1_light",
                "L2_moderate",
                "L3_deep",
                "L4_flashbulb"
            ]
        },
        "memory_color": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "qualia": {
            "type": "object",
            "required": [
                "intensity"
            ],
            "properties": {
                "intensity": {
                    "type": "number"
                },
                "tone": {
                    "type": "string"
                },
                "coherence": {
                    "type": "number"
                },
                "depth": {
                    "type": "number"
                },
                "texture": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "number"
                    }
                }
            }
        },
        "resonance_texture": {
            "type": "object",
            "properties": {
                "stress": {
                    "type": "number"
                },
                "warmth": {
                    "type": "number"
                },
                "clarity": {
                    "type": "number"
                },
                "drive": {
                    "type": "number"
                },
                "calm": {
                    "type": "number"
                }
            }
        },
        "trauma_flag": {
            "type": "boolean"
        },
        "reflex_directives": {
            "type": "object",
            "additionalProperties": true
        },
        "reflex": {
            "type": "object",
            "properties": {
                "threat_level": {
                    "type": "number"
                }
            }
        },
        "physio": {
            "type": "object",
            "properties": {
                "vitals": {
                    "$ref": "#/definitions/VitalsData"
                },
                "hormones": {
                    "$ref": "#/definitions/HormonePanel"
                }
            }
        }
    }
}